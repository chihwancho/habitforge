{
  "name": "habitforge",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "web": "npm run dev --workspace=apps/web",
    "mobile": "npm run start --workspace=apps/mobile",
    "build": "npm run build --workspaces",
    "db:push": "npm run db:push --workspace=packages/db",
    "db:generate": "npm run db:generate --workspace=packages/db",
    "db:studio": "npm run db:studio --workspace=packages/db"
  }
}
