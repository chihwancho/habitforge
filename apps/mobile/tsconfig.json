{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@habitforge/shared": ["../../packages/shared/src"],
      "@habitforge/shared/*": ["../../packages/shared/src/*"],
      "@habitforge/db": ["../../packages/db/src"],
      "@habitforge/db/*": ["../../packages/db/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
